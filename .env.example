# API Configuration
# Leave unset in the UAT build (same-origin: the SPA and /api are both served
# from aws.72street.ai via CloudFront). For local dev, point at your backend:
# VITE_API_BASE=http://localhost:8000

# AWS Cognito Auth (required for Sign in / login).
# The pool region is inferred from the pool id. The user-pool id and app-client
# id are public identifiers (safe to ship in the bundle); there is NO client secret.
VITE_COGNITO_REGION=ap-south-1
VITE_COGNITO_USER_POOL_ID=ap-south-1_xxxxxxxxx
VITE_COGNITO_CLIENT_ID=xxxxxxxxxxxxxxxxxxxxxxxxxx
# Hosted-UI domain for Google OAuth (Authorization Code + PKCE):
VITE_COGNITO_DOMAIN=your-domain.auth.ap-south-1.amazoncognito.com

# For local development, uncomment:
# VITE_API_BASE=http://localhost:7860

# Admin dashboard (optional) — client-side email allowlist that decides who SEES
# the admin UI. The real authorization is server-side (require_admin verifies the
# Cognito token against the backend ADMIN_EMAILS allowlist).
# VITE_ADMIN_EMAILS=admin@example.com,you@company.com
# NOTE: never put an admin secret in a VITE_* var — Vite inlines it into the
# public JS bundle (SEC-004). Admin endpoints authorize server-side via the
# signed-in user's Cognito token + the backend ADMIN_EMAILS allowlist.

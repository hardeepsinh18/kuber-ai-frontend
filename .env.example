# API Configuration
# Leave unset on Vercel (uses same-origin proxy to AWS). For local dev set:
# VITE_API_BASE=http://13.204.195.79:8000
# VITE_API_BASE=

# Optional: when using private Hugging Face Spaces backend
# VITE_HF_TOKEN=hf_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Supabase Auth (required for Sign in button and login modal)
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your_supabase_anon_key

# For local development, uncomment:
# VITE_API_BASE=http://localhost:7860

# Admin-only Backend logs page (optional)
# VITE_ADMIN_EMAILS=admin@example.com,you@company.com
# VITE_ADMIN_LOGS_SECRET=same-as-ADMIN_LOGS_SECRET-on-EC2-backend
